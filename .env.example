# CukaiPandai — environment template. Copy to .env and fill in REAL values there.
# .env and .env.local are gitignored; THIS file (placeholders only) is safe to commit.
# NEVER put real secrets in .env.example.

# --- MyInvois (LHDN e-invoicing) — sandbox/preprod ---
MYINVOIS_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_TIN=
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET_1=
MYINVOIS_CLIENT_SECRET_2=

# --- Model layer (see api/llm.py) ---
# ILMU-first (sovereign primary): LLM_PROVIDER=openai, LLM_BASE_URL=https://api.ilmu.ai/v1, LLM_MODEL=nemo-super
# Claude fallback:                LLM_PROVIDER=anthropic, LLM_MODEL=claude-opus-4-8
LLM_PROVIDER=openai
LLM_MODEL=nemo-super
LLM_BASE_URL=https://api.ilmu.ai/v1
LLM_API_KEY=

# --- Frontend (Next.js — frontend/) ---
# Mock-by-default: the UI runs with no backend when API_MOCK=1.
NEXT_PUBLIC_API_MOCK=1
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_SOVEREIGN=0
