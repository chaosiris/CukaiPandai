# CukaiPandai — environment template. Copy to .env and fill in REAL values there.
# .env and .env.local are gitignored; THIS file (placeholders only) is safe to commit.
# NEVER put real secrets in .env.example.

# --- MyInvois (LHDN e-invoicing) — sandbox/preprod ---
MYINVOIS_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_TIN=
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET_1=
MYINVOIS_CLIENT_SECRET_2=

# --- Model layer (read at request time by make_llm() in backend/api/llm.py) ---
# ILMU (sovereign primary) — issue the key at https://console.ilmu.ai (Claw Starter plan):
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.ilmu.ai/v1
#   LLM_MODEL=nemo-super        # heavier sovereign model; use ilmu-nemo-nano for lighter/faster
# Claude (fallback / escalation):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-opus-4-8
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.ilmu.ai/v1
LLM_MODEL=nemo-super
LLM_API_KEY=                    # ILMU sk-... when provider=openai; Anthropic key when provider=anthropic
# Failover key for the planned RoutingLLMClient (BE-1) — leave blank until wired:
# ANTHROPIC_API_KEY=

# --- Backend runtime ---
# Run from backend/:  cd backend && uv run uvicorn api.main:app --reload
# api/main.py calls load_dotenv() on startup, which finds this repo-root .env automatically.

# --- CORS (BE-7): comma-separated origins allowed to call the API ---
# Local dev needs the Vite origin; add the Vercel preview/prod URL for deploy (DO-1/DO-2).
CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite — frontend/) ---
# Mock-by-default: the UI runs with no backend when VITE_API_MOCK=1.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_MOCK=1
VITE_SOVEREIGN=0
