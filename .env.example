# CukaiPandai — environment template. Copy to .env and fill in REAL values there.
# .env and .env.local are gitignored; THIS file (placeholders only) is safe to commit.
# NEVER put real secrets in .env.example.

# --- MyInvois (LHDN e-invoicing) — sandbox/preprod ---
MYINVOIS_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_TIN=
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET_1=
MYINVOIS_CLIENT_SECRET_2=

# --- Model layer (read at request time by make_llm() in backend/api/llm.py) ---
# ILMU (sovereign primary) — issue the key at https://console.ilmu.ai (Claw Starter plan):
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.ilmu.ai/v1
LLM_MODEL=nemo-super            # heavier sovereign model; ilmu-nemo-nano for lighter/faster
LLM_API_KEY=                    # ILMU sk-...
#
# Escalation / failover (the RoutingLLMClient secondary). SOVEREIGN by default — a stronger model
# on the SAME ILMU gateway, so inference stays 100% in-country. Leave blank for pure-ILMU (the
# 28 Jun prelim, Q6 — no router is built):
# LLM_ESCALATION_MODEL=         # e.g. a larger ILMU model id (reuses LLM_BASE_URL + LLM_API_KEY)
# LLM_ESCALATION_BASE_URL=      # optional override (keep on api.ilmu.ai to stay sovereign)
# LLM_ESCALATION_API_KEY=       # optional override
#
# NON-SOVEREIGN opt-in — a DIRECT Anthropic call LEAVES MALAYSIA (breaks data residency / the
# sovereignty pitch). Off unless BOTH are set; choose deliberately and state it in the deck:
# LLM_ALLOW_DIRECT_ANTHROPIC=1
# ANTHROPIC_API_KEY=
# LLM_FALLBACK_MODEL=claude-opus-4-8

# --- Backend runtime ---
# Run from backend/:  cd backend && uv run uvicorn api.main:app --reload
# api/main.py calls load_dotenv() on startup, which finds this repo-root .env automatically.

# --- Persistence (DO-4 / BE-15/16/17): managed Neon Postgres (SG region, free tier) ---
# Plain Postgres via a connection string (no SDK). Leave BLANK to run on the in-memory/fixtures
# fallback (DB-down != demo-down). Pooled URL for runtime; unpooled (direct) for one-time setup().
# DATABASE_URL=postgresql://<user>:<pwd>@<ep>-pooler.ap-southeast-1.aws.neon.tech/<db>?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://<user>:<pwd>@<ep>.ap-southeast-1.aws.neon.tech/<db>?sslmode=require

# --- CORS (BE-7): comma-separated origins allowed to call the API ---
# Local dev needs the Vite origin; add the Vercel preview/prod URL for deploy (DO-1/DO-2).
CORS_ORIGINS=http://localhost:5173

# --- Auth (real backend: hashed passwords + signed JWT + Google SSO) ---
# JWT signing secret — CHANGE THIS in production (the code falls back to an insecure dev default).
#   generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=
# Google SSO is OFF until BOTH are set (server + client) AND the `auth-google` extra is installed
# (cd backend && uv sync --extra auth-google). Until then /auth/google returns 503; email/password
# + guest still work. NOTE: Google is a US service — enabling it sends auth data abroad (residency
# caveat; state it in the deck, like the Neon-SG caveat). Use the SAME OAuth client ID both sides:
# GOOGLE_CLIENT_ID=<your-id>.apps.googleusercontent.com

# --- Frontend (Vite — frontend/) ---
# Mock-by-default: the UI runs with no backend when VITE_API_MOCK=1.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_MOCK=1
VITE_SOVEREIGN=0
# Google SSO client ID for the browser (Google Identity Services). Same value as GOOGLE_CLIENT_ID.
# Leave blank to keep the Google button in mock/simulated mode.
VITE_GOOGLE_CLIENT_ID=
