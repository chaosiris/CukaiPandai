# Backend origin — set to your Render URL for live mode
# Default (omit or leave blank): http://localhost:8000
VITE_API_BASE_URL=https://cukaipandai-api.onrender.com

# Mock mode — set to '1' to bypass the backend entirely (uses in-memory fixtures)
# Unset or '0' for live mode
VITE_API_MOCK=0

# Google SSO client ID (public — safe to commit). Same value as the backend GOOGLE_CLIENT_ID.
# Leave blank to keep the Google button in mock/simulated mode (needs VITE_API_MOCK=0 to go live).
VITE_GOOGLE_CLIENT_ID=845795239543-i4618tk19ccnb418ja60fn9m4bmkencu.apps.googleusercontent.com
